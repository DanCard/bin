#!/bin/bash
# Set XFCE power management settings based on DPMS sleep time

print_help() {
    echo "Usage: $0 <sleep-minutes> [suspend-minutes]"
    echo ""
    echo "Example: $0 10"
    echo "  Sets DPMS sleep to 10 minutes"
    echo "  Sets DPMS off to 11 minutes (sleep + 1)"
    echo "  Sets system suspend to 20 minutes (sleep x 2)"
    echo ""
    echo "Example: $0 10 60"
    echo "  Sets DPMS sleep to 10 minutes"
    echo "  Sets DPMS off to 11 minutes (sleep + 1)"
    echo "  Sets system suspend to 60 minutes (explicitly)"
}

if [ -z "$1" ]; then
    exec "$HOME/bin/sps"
fi

case "$1" in
    -h|--help|help)
        print_help
        exit 0
        ;;
esac

# echo "Current settings:"
sps  # show-power-settings

CONFIG_FILE="$HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-power-manager.xml"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Configuration file not found at $CONFIG_FILE"
    exit 1
fi

if [[ "$1" =~ ^[0-9]+$ ]]; then
    SLEEP_TIME="$1"
    if [ "$SLEEP_TIME" -eq 0 ]; then
        DPMS_SLEEP_TIME=1
        DPMS_OFF_TIME=1
        SUSPEND_TIME=1
    else
        DPMS_SLEEP_TIME="$SLEEP_TIME"
        DPMS_OFF_TIME=$((DPMS_SLEEP_TIME + 1))
        if [ "$SLEEP_TIME" -gt 5 ]; then
			SUSPEND_TIME=$((DPMS_SLEEP_TIME * DPMS_OFF_TIME))
		elif [ "$SLEEP_TIME" -lt 5]; then
			if [ "$SLEEP_TIME" -lt 3]; then
	        	SUSPEND_TIME=$((SLEEP_TIME + 1))
	        else
	        	SUSPEND_TIME=$((SLEEP_TIME * 2))
	        fi
	    else
	    	SUSPEND_TIME=20
	    fi
    fi

    # Override suspend time if second argument is provided
    if [[ -n "$2" ]]; then
        if [[ "$2" =~ ^[0-9]+$ ]]; then
            SUSPEND_TIME="$2"
        else
            echo "Error: Second argument must be a valid number"
            exit 1
        fi
    fi
else
    echo "Error: Please provide a valid number"
    exit 1
fi

set -x  # Enable command echoing

xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-sleep -s $DPMS_SLEEP_TIME || \
  xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-sleep -n -t uint -s $DPMS_SLEEP_TIME

xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-off -s $DPMS_OFF_TIME || \
  xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-on-ac-off -n -t uint -s $DPMS_OFF_TIME

xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-on-ac -s $SUSPEND_TIME || \
  xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/inactivity-on-ac -n -t uint -s $SUSPEND_TIME

xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-enabled -s true || \
  xfconf-query -c xfce4-power-manager -p /xfce4-power-manager/dpms-enabled -n -t bool -s true

xset +dpms

set +x  # Disable command echoing
