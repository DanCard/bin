#!/bin/bash

# adb-refresh
# Detects connected USB Android devices and switches them to Wireless ADB mode.

echo "Scanning for USB Android devices..."

# Get list of devices (excluding emulators and existing network connections)
# 1. 'adb devices' - list devices
# 2. 'grep "device$"' - only active devices
# 3. 'awk ...' - get serial
# 4. 'grep -v ":"' - exclude IP:PORT (wireless) devices
# 5. 'grep -v "emulator"' - exclude emulators
usb_devices=$(adb devices | grep "device$" | awk '{print $1}' | grep -v ":" | grep -v "emulator")

if [ -z "$usb_devices" ]; then
    echo "No USB devices detected. connect them via USB first."
    exit 0
fi

for serial in $usb_devices; do
    echo "----------------------------------------"
    echo "Setting up device: $serial"
    
    # Get IP address from wlan0 interface
    ip=$(adb -s "$serial" shell ip -f inet addr show wlan0 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -n 1)
    
    if [ -z "$ip" ]; then
        echo "  [Error] Could not find Wi-Fi IP address. Ensure the device is connected to Wi-Fi."
        continue
    fi
    
    echo "  IP Address: $ip"
    echo "  Enabling TCP/IP mode on port 5555..."
    adb -s "$serial" tcpip 5555
    
    echo "  Waiting for restart..."
    sleep 3
    
    echo "  Connecting wirelessly..."
    adb connect "$ip:5555"
done

echo "----------------------------------------"
echo "All done! Here is your device list:"
adb devices
