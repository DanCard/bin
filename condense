#!/usr/bin/env python3
import os
import sys
import time
import json
import argparse
import subprocess
import shutil
import requests
import psutil

# Configuration
LLAMA_SERVER_BIN = os.path.expanduser("~/github/llama.cpp/build/bin/llama-server")
MODEL_PATH = os.path.expanduser("~/llms/qwen3/6/mtp-27B-UD-Q8_K_XL.gguf")
MODEL_ID = "llama.cpp/mtp-27B-UD-Q8_K_XL.gguf"
LLAMA_URL = "http://localhost:8080"
DEFAULT_MAX_TOKENS = -1
LOG_PATH = "llama-server.log"

SYSTEM_PROMPT = (
    "Produce an exhaustive report of the meeting. "
    "Capture the full depth of technical discussions and side-bars. Do not omit details for brevity. "
    "Use markdown formatting with clear headers, bullet or numbered points, and tables for structured data. "
    "Include lots of quotes and excerpts inline within the topical sections"
    # ; do not create a separate 'Notable Quotes' section at the end."
)

USER_PROMPT_PREFIX = (
    "Here is the full transcript of a meeting. Provide an incredibly detailed record covering every topic, "
    "every decision, and every specific detail mentioned. Include a list of meeting attendees and comprehensive Action Items table. "
    "Do not summarize or condense; expand on every point made."
    # "Integrate nuance and quotes directly into the relevant discussion points rather than aggregating them at the bottom. "
)

def is_server_running(url):
    """Check if the server is responding to API requests."""
    try:
        response = requests.get(f"{url}/v1/models", timeout=2)
        return response.status_code == 200
    except requests.exceptions.RequestException:
        return False


def is_process_running(name):
    """Check if a process with the given name exists."""
    for proc in psutil.process_iter(['name']):
        if proc.info['name'] == name:
            return True
    return False


def start_server(model_path):
    """Start the llama-server in the background if it's not already running."""
    if is_server_running(LLAMA_URL):
        print("✅ Llama-server is already running and responding.")
        return True

    if is_process_running("llama-server"):
        print("⏳ Llama-server process is running but not responding yet. Waiting...")
    else:
        print("🚀 Llama-server is not running. Starting it now...")
        cmd = [
            LLAMA_SERVER_BIN,
            "-m", model_path,
            "--spec-type", "draft-mtp",
            "--spec-draft-n-max", "3",
            "-ngl", "999",
            "-c", "128000",
            "-fa", "off",
            "-ctk", "q8_0",
            "-ctv", "q8_0",
            "--temp", "0"
        ]

        print(f"📡 Command issued: {' '.join(cmd)}")
        print(f"📝 Logs are being written to {LOG_PATH}")

        try:
            # Open file in context manager; Popen inherits the file descriptor
            with open(LOG_PATH, "a") as log_file:
                subprocess.Popen(
                    cmd,
                    stdout=log_file,
                    stderr=log_file,
                    start_new_session=True
                )
        except Exception as e:
            print(f"❌ Error starting llama-server process: {e}")
            return False

    # Polling loop
    print("⌛ Waiting for server to become ready (this may take a minute)...")
    start_time = time.time()
    while time.time() - start_time < 300:  # 5 minute timeout
        if is_server_running(LLAMA_URL):
            print("\n✅ Llama-server is ready!")
            return True
        print(".", end="", flush=True)
        time.sleep(2)

    print("\n❌ Error: Timeout waiting for llama-server to start.")
    return False


def generate_summary(transcript_path, output_path, max_tokens, url, agent):
    """Send the transcript to the server and stream the response to a file."""
    if not os.path.exists(transcript_path):
        print(f"❌ Error: File not found: {transcript_path}")
        return

    with open(transcript_path, 'r', encoding='utf-8', errors='replace') as f:
        transcript = f.read()

    print(f"📖 Read transcript from {transcript_path} ({len(transcript)} chars)")
    print(f"📝 Generating exhaustive meeting record → {output_path}")
    print(f"💡 Monitor progress in another terminal: tail -f '{output_path}'")
    print("-" * 40)

    payload = {
        "model": MODEL_ID,
        "messages": [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": f"{USER_PROMPT_PREFIX}\n\n{transcript}"}
        ],
        "max_tokens": max_tokens,
        "temperature": 0,
        "stream": True
    }

    try:
        response = requests.post(
            f"{url}/v1/chat/completions",
            headers={"Content-Type": "application/json"},
            json=payload,
            stream=True
        )
        response.raise_for_status()

        char_count = 0
        with open(output_path, 'w') as f_out:
            for line in response.iter_lines():
                if line:
                    decoded_line = line.decode('utf-8')
                    if decoded_line.startswith("data: "):
                        data_str = decoded_line[len("data: "):]
                        if data_str.strip() == "[DONE]":
                            break
                        try:
                            data = json.loads(data_str)
                            content = data['choices'][0]['delta'].get('content', '')
                            if content:
                                # Write to file
                                f_out.write(content)
                                f_out.flush()
                                
                                # Update progress in console
                                char_count += len(content)
                                sys.stdout.write(f"\r⏳ Generating: {char_count} characters written...")
                                sys.stdout.flush()
                        except (json.JSONDecodeError, KeyError):
                            continue
        
        print(f"\n✅ Detailed record saved to: {output_path}")
        create_google_doc(output_path, agent)

    except requests.exceptions.RequestException as e:
        print(f"\n❌ Error calling llama-server: {e}")


def create_google_doc(file_path, agent):
    """Uses the specified CLI agent to create a Google Doc from the markdown file."""
    print(f"📁 Creating Google Doc in defensetech account using {agent}...")
    try:
        agent_path = shutil.which(agent)
        if not agent_path:
            print(f"⚠️ Warning: Could not find CLI agent '{agent}' in PATH.")
            return

        # 1. Switch auth to defensetech
        switch_script = os.path.expanduser("~/.gemini/switch_auth.sh")
        subprocess.run(
            [switch_script, "defensetech"],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )

        # 2. Use chosen CLI to create the doc
        abs_path = os.path.abspath(file_path)
        prompt = (
            f"Create a Google Doc from the markdown file '{abs_path}' using its "
            "content. The title should be based on the meeting title in the file. "
            "Include a clickable link to the new doc."
        )

        if agent == "opencode":
            cmd = [agent_path, "run", "-m", MODEL_ID, prompt]
        else:
            cmd = [agent_path, "--approval-mode", "auto_edit", prompt]

        # Run command without shell=True for safety
        subprocess.run(cmd, check=True)
        print(f"✅ Google Doc creation request sent via {agent}.")

    except subprocess.CalledProcessError as e:
        print(f"⚠️ Warning: Could not create Google Doc automatically: {e}")


def main():
    parser = argparse.ArgumentParser(
        description="Generate exhaustive meeting records using local LLM with progress tracking."
    )
    parser.add_argument("transcript", help="Path to the transcript text file.")
    parser.add_argument(
        "output",
        nargs="?",
        help="Path to the output markdown file (default: transcript.txt.md)."
    )
    parser.add_argument(
        "--max-tokens",
        type=int,
        default=DEFAULT_MAX_TOKENS,
        help="Max output tokens (default: -1)."
    )
    parser.add_argument(
        "--url",
        default=LLAMA_URL,
        help=f"llama-server URL (default: {LLAMA_URL})."
    )
    parser.add_argument(
        "--agent",
        choices=["gemini", "opencode"],
        default="opencode",
        help="CLI agent to use for creating the Google Doc (default: opencode)."
    )

    args = parser.parse_args()

    # Default output path
    if not args.output:
        args.output = args.transcript + ".md"

    # 1. Ensure server is running
    if not start_server(MODEL_PATH):
        sys.exit(1)

    # 2. Generate summary
    generate_summary(args.transcript, args.output, args.max_tokens, args.url, args.agent)


if __name__ == "__main__":
    main()
