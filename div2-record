#!/bin/bash
# Simplified Divinity 2 Recording Script (FFMPEG VAAPI)
# Assumes game is already running.

# 1. Configuration
OUTPUT_DIR="$HOME/Videos/Divinity2"
mkdir -p "$OUTPUT_DIR"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
OUTPUT_FILE="$OUTPUT_DIR/Divinity2_$TIMESTAMP.mkv"
RESOLUTION=$(xdpyinfo | grep dimensions | awk '{print $2}')

# Automatically detect the monitor source (system audio)
AUDIO_MONITOR=$(pactl list sources short | grep monitor | grep RUNNING | awk '{print $2}' | head -n 1)
[ -z "$AUDIO_MONITOR" ] && AUDIO_MONITOR="alsa_output.pci-0000_c6_00.6.analog-stereo.monitor"

# Automatically detect the microphone (default input)
AUDIO_MIC="default"

echo "------------------------------------------------"
echo " Divinity 2 Recording (Simple Mode)"
echo "------------------------------------------------"
echo " Output: $OUTPUT_FILE"
echo " Res:    $RESOLUTION"
echo " Audio:  $AUDIO_MONITOR"
echo " Mic:    $AUDIO_MIC"
echo "------------------------------------------------"
echo " Recording starting in 10 seconds..."
echo " (Switch to your game window now!)"
echo "------------------------------------------------"
for i in {10..1}; do
    echo -n "$i... "
    sleep 1
done
echo -e "\n------------------------------------------------"
echo " Recording started! Press 'q' to stop."
echo "------------------------------------------------"

ffmpeg -hide_banner -loglevel warning -stats \
  -vaapi_device /dev/dri/renderD128 \
  -thread_queue_size 1024 \
  -f x11grab -video_size "$RESOLUTION" -framerate 60 -i :0.0 \
  -thread_queue_size 1024 \
  -f pulse -i "$AUDIO_MONITOR" \
  -thread_queue_size 1024 \
  -f pulse -i "$AUDIO_MIC" \
  -filter_complex "[1:a][2:a]amix=inputs=2:duration=first[a]" \
  -map 0:v -map "[a]" \
  -vf 'format=nv12,hwupload' \
  -c:v hevc_vaapi -rc_mode CQP -qp 18 -async_depth 4 \
  -c:a flac "$OUTPUT_FILE"
