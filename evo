#!/bin/bash

# Usage: evo [device_id]
# If no device_id is provided, defaults to 12

DEVICE_ID="${1:-10}"

# Validate that device exists
if ! xinput list | grep -q "id=$DEVICE_ID"; then
  echo "Error: Device ID $DEVICE_ID not found"
  echo ""
  echo "Available devices:"
  xinput list | grep "pointer" | grep -v "XTEST"
  exit 1
fi

while true; do
  clear

  # Be sure to use the device id produced by the output of `xinput list`!
  xinput query-state "$DEVICE_ID"

  # Alternatively, you can use the full device name:
  #     xinput query-state "Kingsis Peripherals Evoluent VerticalMouse 4"
  # will work as well.

  sleep 0.1
done
